@model IEnumerable<Student>

@{
    ViewData["Title"] = "Student List";
}

<div class="container mt-4">
    <h2 class="text-primary">All Students</h2>
    <p class="text-muted">Total Students: @Model.Count()</p>

    <a asp-action="Create" class="btn btn-success mb-3">+ Add New Student</a>

    <table class="table table-hover table-bordered shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Age</th>
                <th>Email</th>
                <th>Department</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model)
            {
                <tr>
                    <td>@student.Id</td>
                    <td>@student.Name</td>
                    <td>@student.Age</td>
                    <td>@student.Email</td>
                    <td>@(student.Department?.Name ?? "N/A")</td>
                    <td>
                        <a asp-action="Details" asp-controller="Student" asp-route-id="@student.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-controller="Student" asp-route-id="@student.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-controller="Student" asp-route-id="@student.Id" class="btn btn-sm btn-danger"
                           onclick="return confirm('Are you sure you want to delete student: @student.Name?')">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>