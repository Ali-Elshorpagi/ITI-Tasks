@{
    Layout = null;
    ViewData["Title"] = "AI - n8n";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <style>
    :root {
        --bg-color: #fdfcfb;
        --text-color: #333;
        --text-secondary: #666;
        --input-bg: white;
        --input-border: #e5e5e5;
        --input-shadow: rgba(0,0,0,0.05);
        --input-focus-border: #a3a3a3;
        --input-focus-shadow: rgba(0,0,0,0.08);
        --user-avatar-bg: #e3e3e3;
        --user-avatar-color: #333;
        --ai-avatar-bg: #d97757;
        --ai-avatar-color: white;
        --btn-bg: #333;
        --btn-color: white;
        --btn-hover-bg: #000;
        --theme-toggle-bg: #eaeaea;
        --theme-toggle-color: #333;
    }

    [data-theme="dark"] {
        --bg-color: #1e1e1e;
        --text-color: #e0e0e0;
        --text-secondary: #aaaaaa;
        --input-bg: #2d2d2d;
        --input-border: #444;
        --input-shadow: rgba(0,0,0,0.2);
        --input-focus-border: #666;
        --input-focus-shadow: rgba(0,0,0,0.3);
        --user-avatar-bg: #444;
        --user-avatar-color: #e0e0e0;
        --ai-avatar-bg: #c25e3e;
        --ai-avatar-color: white;
        --btn-bg: #e0e0e0;
        --btn-color: #1e1e1e;
        --btn-hover-bg: #fff;
        --theme-toggle-bg: #333;
        --theme-toggle-color: #e0e0e0;
    }

    body, html {
        height: 100%;
        background-color: var(--bg-color);
        color: var(--text-color);
        transition: background-color 0.3s, color 0.3s;
    }
    main {
        padding: 0 !important;
        margin: 0 !important;
        max-width: 100% !important;
    }
    .chat-container {
        display: flex;
        flex-direction: column;
        height: calc(100vh - 120px);
        max-width: 800px;
        margin: 0 auto;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    }
    .top-bar {
        display: flex;
        justify-content: flex-end;
        padding: 10px 20px 0;
    }
    .theme-toggle {
        background: var(--theme-toggle-bg);
        color: var(--theme-toggle-color);
        border: none;
        border-radius: 20px;
        padding: 6px 12px;
        font-size: 14px;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: background-color 0.2s, color 0.2s;
    }
    .messages-area {
        flex-grow: 1;
        overflow-y: auto;
        padding: 10px 20px 20px;
        display: flex;
        flex-direction: column;
        gap: 32px;
    }
    .message {
        display: flex;
        gap: 16px;
        line-height: 1.6;
    }
    .avatar {
        width: 32px;
        height: 32px;
        border-radius: 4px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        flex-shrink: 0;
        font-size: 14px;
    }
    .avatar-user {
        background-color: var(--user-avatar-bg);
        color: var(--user-avatar-color);
    }
    .avatar-ai {
        background-color: var(--ai-avatar-bg);
        color: var(--ai-avatar-color);
    }
    .message-content {
        flex-grow: 1;
        font-size: 16px;
        color: var(--text-color);
        padding-top: 4px;
    }
    .input-area {
        padding: 20px;
        background: transparent;
    }
    .input-wrapper {
        position: relative;
        background: var(--input-bg);
        border: 1px solid var(--input-border);
        border-radius: 16px;
        box-shadow: 0 4px 12px var(--input-shadow);
        padding: 14px 48px 14px 20px;
        transition: border-color 0.2s, box-shadow 0.2s, background-color 0.3s;
    }
    .input-wrapper:focus-within {
        border-color: var(--input-focus-border);
        box-shadow: 0 4px 12px var(--input-focus-shadow);
    }
    textarea.chat-input {
        width: 100%;
        border: none;
        resize: none;
        outline: none;
        font-size: 16px;
        max-height: 200px;
        min-height: 24px;
        background: transparent;
        color: var(--text-color);
        padding: 0;
        margin: 0;
        display: block;
    }
    textarea.chat-input::placeholder {
        color: var(--text-secondary);
    }
    .send-button {
        position: absolute;
        right: 12px;
        bottom: 10px;
        background: var(--btn-bg);
        color: var(--btn-color);
        border: none;
        border-radius: 10px;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: background 0.2s, color 0.2s;
    }
    .send-button:hover {
        background: var(--btn-hover-bg);
    }
    .greeting {
        text-align: center;
        margin-top: 20vh;
        color: var(--text-color);
    }
    .greeting h2 {
        font-weight: 500;
        font-size: 2rem;
        margin-bottom: 8px;
    }
    .greeting p {
        color: var(--text-secondary);
        font-size: 1.1rem;
    }
</style>
</head>
<body>

<div class="chat-container">
    <div class="top-bar">
        <button id="themeToggle" class="theme-toggle">
            <svg id="themeIcon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <!-- Default to moon icon -->
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
            <span id="themeText">Dark Mode</span>
        </button>
    </div>
    <div class="messages-area">
        @if (!string.IsNullOrEmpty(ViewBag.Error))
        {
            <div class="alert alert-danger mx-3">@ViewBag.Error</div>
        }

        @if (!string.IsNullOrEmpty(ViewBag.Question))
        {
            <!-- User Message -->
            <div class="message">
                <div class="avatar avatar-user">U</div>
                <div class="message-content">
                    @ViewBag.Question
                </div>
            </div>

            <!-- AI Response -->
            @if (!string.IsNullOrEmpty(ViewBag.Answer))
            {
                <div class="message">
                    <div class="avatar avatar-ai">AI</div>
                    <div class="message-content">
                        @Html.Raw(ViewBag.Answer.Replace("\n", "<br/>"))
                    </div>
                </div>
            }
        }
        else
        {
            <!-- Empty State Greeting -->
            <div class="greeting">
                <h2>Good afternoon</h2>
                <p>Ready to solve some math problems? Ask me anything about mathematics!</p>
            </div>
        }
    </div>

    <div class="input-area">
        <form asp-controller="AI" asp-action="Ask" method="post">
            <div class="input-wrapper">
                <textarea class="chat-input" id="question" name="question" rows="1" required placeholder="Message AI..."></textarea>
                <button type="submit" class="send-button" aria-label="Send">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="22" y1="2" x2="11" y2="13"></line>
                        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                    </svg>
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    // Auto-resize textarea
    const tx = document.getElementById("question");
    if (tx) {
        tx.setAttribute("style", "height:" + (tx.scrollHeight) + "px;overflow-y:hidden;");
        tx.addEventListener("input", function() {
            this.style.height = "auto";
            this.style.height = (this.scrollHeight) + "px";
        }, false);

        tx.addEventListener("keydown", function(e) {
            if (e.key === "Enter" && !e.shiftKey) {
                e.preventDefault(); // Prevent the default behavior of inserting a newline
                if (this.value.trim() !== "") {
                    this.closest("form").submit(); // Submit the form
                }
            }
        });
    }

    // Theme toggle functionality
    const themeToggleBtn = document.getElementById("themeToggle");
    const themeIcon = document.getElementById("themeIcon");
    const themeText = document.getElementById("themeText");
    const htmlElement = document.documentElement;

    const sunIcon = `<circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>`;
    const moonIcon = `<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>`;

    function setTheme(isDark) {
        if (isDark) {
            htmlElement.setAttribute("data-theme", "dark");
            themeIcon.innerHTML = sunIcon;
            themeText.textContent = "Light Mode";
            localStorage.setItem("theme", "dark");
        } else {
            htmlElement.removeAttribute("data-theme");
            themeIcon.innerHTML = moonIcon;
            themeText.textContent = "Dark Mode";
            localStorage.setItem("theme", "light");
        }
    }

    // Check saved theme
    const savedTheme = localStorage.getItem("theme");
    if (savedTheme === "dark" || (!savedTheme && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
        setTheme(true);
    } else {
        setTheme(false);
    }

    themeToggleBtn.addEventListener("click", () => {
        const isDark = htmlElement.getAttribute("data-theme") === "dark";
        setTheme(!isDark);
    });
</script>
</body>
</html>
