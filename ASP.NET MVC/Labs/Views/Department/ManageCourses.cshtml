@model DepartmentCoursesViewModel

@{
    ViewData["Title"] = "Manage Courses - " + Model.Department.Name;
}

<div class="container mt-4">
    <h2 class="text-primary">Manage Courses — <span class="text-dark">@Model.Department.Name</span></h2>
    <a asp-action="Index" class="btn btn-secondary mb-4">← Back to Departments</a>

    <div class="row">
        <div class="col-md-6">
            <div class="card border-success">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Assigned Courses (@Model.AssignedCourses.Count)</h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.AssignedCourses.Any())
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Duration</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var course in Model.AssignedCourses)
                                {
                                    <tr>
                                        <td>@course.Id</td>
                                        <td>@course.Name</td>
                                        <td>@course.Duration hrs</td>
                                        <td>
                                            <form asp-action="RemoveCourse" method="post">
                                                <input type="hidden" name="departmentId" value="@Model.Department.Id" />
                                                <input type="hidden" name="courseId" value="@course.Id" />
                                                <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted p-3 mb-0">No courses assigned yet.</p>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-secondary">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">Available Courses (@Model.AvailableCourses.Count)</h5>
                </div>
                <div class="card-body p-0">
                    @if (Model.AvailableCourses.Any())
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>ID</th>
                                    <th>Name</th>
                                    <th>Duration</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var course in Model.AvailableCourses)
                                {
                                    <tr>
                                        <td>@course.Id</td>
                                        <td>@course.Name</td>
                                        <td>@course.Duration hrs</td>
                                        <td>
                                            <form asp-action="AddCourse" method="post">
                                                <input type="hidden" name="departmentId" value="@Model.Department.Id" />
                                                <input type="hidden" name="courseId" value="@course.Id" />
                                                <button type="submit" class="btn btn-sm btn-success">Add</button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <p class="text-muted p-3 mb-0">All courses are already assigned.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
