@model StudentViewModel

@{
    ViewData["Title"] = "Create Student";
}

<div class="container mt-4">
    <h2 class="text-primary">Add New Student</h2>
    <hr />

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <table class="table table-bordered" style="max-width: 600px;">
            <tbody>
                <tr>
                    <th class="table-primary">Name</th>
                    <td>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </td>
                </tr>
                <tr>
                    <th class="table-primary">Age</th>
                    <td>
                        <input asp-for="Age" type="number" class="form-control" />
                        <span asp-validation-for="Age" class="text-danger"></span>
                    </td>
                </tr>
                <tr>
                    <th class="table-primary">Email</th>
                    <td>
                        <input asp-for="Email" type="email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </td>
                </tr>
                <tr>
                    <th class="table-primary">Department</th>
                    <td>
                        <select asp-for="DepartmentId" class="form-control">
                            <option value="">-- Select Department --</option>
                            @if (ViewBag.Depts is not null)
                            {
                                @foreach (var dept in ViewBag.Depts)
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="DepartmentId" class="text-danger"></span>
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="mt-3">
            <button type="submit" class="btn btn-success">Save Student</button>
            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
}