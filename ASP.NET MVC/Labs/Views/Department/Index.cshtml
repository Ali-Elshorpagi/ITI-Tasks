@model IEnumerable<Department>

@{
    ViewData["Title"] = "Department List";
}

<div class="container mt-4">
    <h2 class="text-primary">All Departments</h2>
    <p class="text-muted">Total Departments: @Model.Count()</p>

    <a asp-action="Create" class="btn btn-success mb-3">+ Add New Department</a>

    <table class="table table-hover table-bordered shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Department Name</th>
                <th>Capacity</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var dept in Model)
            {
                <tr>
                    <td>@dept.Id</td>
                    <td>@dept.Name</td>
                    <td>@dept.Capacity</td>
                    <td>
                        <a asp-action="Details" asp-controller="Department" asp-route-id="@dept.Id" class="btn btn-sm btn-info"> Details </a>
                        <a asp-action="Edit" asp-controller="Department" asp-route-id="@dept.Id" class="btn btn-sm btn-warning"> Edit </a>
                        <a asp-action="ManageCourses" asp-controller="Department" asp-route-id="@dept.Id" class="btn btn-sm btn-primary"> Manage Cources</a>
                        <a asp-action="Delete" asp-controller="Department" asp-route-id="@dept.Id"
                           class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this department?')"> Delete </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>