@model Course

@{
    ViewData["Title"] = "Edit Course";
}

<div class="container mt-4">
    <h2 class="text-primary">Edit Course</h2>
    <hr />

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />

        <table class="table table-bordered shadow-sm" style="max-width: 500px;">
            <tbody>
                <tr>
                    <th class="table-primary" style="width: 30%;">Course ID</th>
                    <td>
                        <input class="form-control" value="@Model.Id" readonly disabled />
                    </td>
                </tr>
                <tr>
                    <th class="table-primary">Name</th>
                    <td>
                        <input asp-for="Name" class="form-control" required />
                    </td>
                </tr>
                <tr>
                    <th class="table-primary">Duration (hrs)</th>
                    <td>
                        <input asp-for="Duration" type="number" class="form-control" required />
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="mt-3">
            <button type="submit" class="btn btn-warning px-4">Update Course</button>
            <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
        </div>
    </form>
</div>
