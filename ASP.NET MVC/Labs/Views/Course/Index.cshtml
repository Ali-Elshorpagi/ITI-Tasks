@model IEnumerable<Course>

@{
    ViewData["Title"] = "Course List";
}

<div class="container mt-4">
    <h2 class="text-primary">All Courses</h2>
    <p class="text-muted">Total Courses: @Model.Count()</p>

    <a asp-action="Create" class="btn btn-success mb-3">+ Add New Course</a>

    <table class="table table-hover table-bordered shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Course Name</th>
                <th>Duration (hrs)</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var course in Model)
            {
                <tr>
                    <td>@course.Id</td>
                    <td>@course.Name</td>
                    <td>@course.Duration</td>
                    <td>
                        <a asp-action="Details" asp-controller="Course" asp-route-id="@course.Id" class="btn btn-sm btn-info">Details</a>
                        <a asp-action="Edit" asp-controller="Course" asp-route-id="@course.Id" class="btn btn-sm btn-warning">Edit</a>
                        <a asp-action="Delete" asp-controller="Course" asp-route-id="@course.Id"
                           class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this course?')">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
