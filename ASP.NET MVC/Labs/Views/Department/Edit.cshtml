@model Department

@{
    ViewData["Title"] = "Edit Department";
}

<div class="container mt-4">
    <h2 class="text-primary">Edit Department</h2>
    <hr />

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <table class="table table-bordered shadow-sm" style="max-width: 500px;">
            <tbody>
                <tr>
                    <th class="table-primary" style="width: 30%;">Department ID</th>
                    <td>
                        <input class="form-control" value="@Model.Id" readonly disabled />
                    </td>
                </tr>
                <tr>
                    <th class="table-primary">Name</th>
                    <td>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </td>
                </tr>
                <tr>
                    <th class="table-primary">Capacity</th>
                    <td>
                        <input asp-for="Capacity" type="number" class="form-control" />
                        <span asp-validation-for="Capacity" class="text-danger"></span>
                    </td>
                </tr>
            </tbody>
        </table>

        <div class="mt-3">
            <button type="submit" class="btn btn-warning px-4">Update Department</button>
            <a asp-action="Index" class="btn btn-secondary px-4">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
}